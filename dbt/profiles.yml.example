air_traffic_pulse_dbt:
  target: dev
  outputs:
    dev:
      type: duckdb
      # Path is resolved relative to the CWD where dbt is invoked (repo root
      # when using --project-dir dbt --profiles-dir dbt from the Makefile).
      # Override by setting DUCKDB_PATH=... in the environment.
      path: "{{ env_var('DUCKDB_PATH', 'data/air_traffic_pulse.duckdb') }}"
      # All dbt models land in the "dbt" DuckDB schema (separate from "raw").
      schema: dbt
      threads: 4
