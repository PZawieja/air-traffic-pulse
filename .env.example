# OpenSky Network credentials (optional — anonymous access is rate-limited)
# Register at https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Path to the local DuckDB database file (created automatically on first run)
DUCKDB_PATH=./data/air_traffic_pulse.duckdb

# Comma-separated list of city bounding-box presets to ingest
# Available built-ins: berlin, frankfurt, london
OPENSKY_BBOX_PRESETS=berlin,frankfurt,london
